# -*- python -*-

# ---- Motif build (original) ----
env = Environment(tools=['default', 'prefixoptions', 'vardb', 'netcdf', 'raf'])

env.Append(CXXFLAGS=Split("-std=c++11 -Wall -g -O2 -Wno-write-strings"))
env.Append(LIBS=Split("Xm Xt X11 Xext"))

srcs = Split("vared.cc initv.cc Xwin.cc ccb.cc")

vared = env.Program("vared", srcs)

env.Default(vared)

if env.get('INSTALL_VARDB') and env['INSTALL_VARDB'] == True:
  env.Install(env['INSTALL_PREFIX']+'/bin', vared)

# ---- apply_deptable: DependTable vardb XML importer ----
dt_env = Environment(tools=['default', 'prefixoptions', 'vardb'])
dt_env.Append(CXXFLAGS=Split("-std=c++17 -Wall -g -O2"))
apply_deptable = dt_env.Program("apply_deptable", ["apply_deptable.cc"])
dt_env.Default(apply_deptable)

if dt_env.get('INSTALL_VARDB') and dt_env['INSTALL_VARDB'] == True:
    dt_env.Install(dt_env['INSTALL_PREFIX']+'/bin', apply_deptable)

# ---- Qt5 build ----
# Propagate PKG_CONFIG_PATH from the shell, then append the standard rpm
# layout path so pkg-config finds Qt5 even when it is not in the user's
# environment (common on RHEL/Fedora where qt5-qtbase-devel installs .pc
# files under /usr/lib64/pkgconfig rather than the default search path).
#import os
#_rpm_qt5_pc = '/usr/lib64/pkgconfig'
#_pkg_config_path = os.environ.get('PKG_CONFIG_PATH', '')
#if _rpm_qt5_pc not in _pkg_config_path.split(':'):
#    os.environ['PKG_CONFIG_PATH'] = ':'.join(filter(None, [_pkg_config_path, _rpm_qt5_pc]))

qt_env = Environment(tools=['default', 'prefixoptions', 'vardb', 'netcdf', 'raf', 'qt5'])

qt_env.Append(CXXFLAGS=Split("-std=c++17 -Wall -g -O2"))

# EnableQtModules sets up CPPPATH/LIBS regardless of its return value.
# The return value is inverted in the eol_scons tool (returns False on
# success on Linux), so use QT5_MOC set by generate() only when Qt
# is actually found — as the reliable availability check instead.
qt_env.EnableQtModules(['QtCore', 'QtWidgets'])
if qt_env.get('QT5_MOC'):
    # Build VaredMainWindow as a static convenience library so the test suite
    # can link against it without recompiling under a different Qt environment.
    vmw_lib = qt_env.StaticLibrary('varedmw', ['VaredMainWindow.cc'])
    Export({'vmw_lib': vmw_lib})

    # Link libvaredmw.a via LIBS so the automoc emitter never sees the .a node.
    qt_env_prog = qt_env.Clone()
    qt_env_prog.Prepend(LIBS=['varedmw'])
    qt_env_prog.Prepend(LIBPATH=['.'])
    vared_qt = qt_env_prog.Program("vared_qt", ['main.cc', 'DependTableMerge.cc'])
    qt_env_prog.Depends(vared_qt, vmw_lib)
    qt_env.Alias('vared_qt', vared_qt)
    qt_env.Default(vared_qt)

    if qt_env.get('INSTALL_VARDB') and qt_env['INSTALL_VARDB'] == True:
        qt_env.InstallProgram(vared_qt)
else:
    Export({'vmw_lib': []})
    print("Qt5 not found skipping vared_qt build")
